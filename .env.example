# Supabase/PostgreSQL database connections
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# Redis (use memory:// for local dev without Redis, or actual Redis URL for production)
REDIS_URL="memory://"

# JWT Secrets (Use strong random strings in production!)
JWT_ACCESS_SECRET="your_secure_access_secret_here"
JWT_REFRESH_SECRET="your_secure_refresh_secret_here"

# Supabase OAuth Settings
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Stripe
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_test_xxx"

# SMTP (Email)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your_app_password"

# URLs
FRONTEND_URL="https://v19plus.com"
NEXT_PUBLIC_API_URL="https://api.v19plus.com"
ADMIN_URL="https://admin.v19plus.com"

# Backend
PORT=4000
NODE_ENV="development"
ADMIN_PASSWORD="change_this_admin_password_for_root"
